{
  "name": "portfolio-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @portfolio/web",
    "dev:api": "npm run dev --workspace @portfolio/api",
    "build:web": "npm run build --workspace @portfolio/web",
    "build:api": "npm run build --workspace @portfolio/api",
    "build": "npm run build:web && npm run build:api",
    "lint": "npm run lint --workspace @portfolio/web",
    "test:web": "npm run build:web && npm run test --workspace @portfolio/web"
  }
}
