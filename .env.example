CONTACT_API_URL=https://api.carlsdaleescalo.com/api/contact
CONTACT_FORM_TOKEN_SECRET=replace-with-a-long-random-secret
CONTACT_PROXY_SHARED_SECRET=replace-with-a-different-long-random-secret
CONTACT_TOKEN_TTL_MS=3600000
NODE_ENV=production
# Legacy fallback if you still post directly from the browser. Prefer CONTACT_API_URL.
NEXT_PUBLIC_CONTACT_API_URL=
ALLOWED_ORIGINS=https://carlsdaleescalo.com,https://www.carlsdaleescalo.com
WEB_ORIGIN=https://carlsdaleescalo.com
TRUST_PROXY_HOPS=1
MONGODB_URI=
MONGODB_DB_NAME=contactForm
CONTACT_COLLECTION=contact_submissions
CONTACT_ALLOWED_PRODUCTION_ORIGINS=https://carlsdaleescalo.com,https://www.carlsdaleescalo.com
CONTACT_MIN_SUBMISSION_AGE_MS=2500
CONTACT_MAX_SUBMISSION_AGE_MS=7200000
CONTACT_DUPLICATE_WINDOW_MS=900000
